+<script>
+// ── Star Field ──────────────────────────────────────────────
+(function() {
+  const canvas = document.getElementById('starfield');
+  const ctx = canvas.getContext('2d');
+  let stars = [];
+  const STAR_COUNT = 200;
+
+  function resize() {
+    canvas.width = window.innerWidth;
+    canvas.height = window.innerHeight;
+  }
+
+  function init() {
+    resize();
+    stars = [];
+    for (let i = 0; i < STAR_COUNT; i++) {
+      stars.push({
+        x: Math.random() * canvas.width,
+        y: Math.random() * canvas.height,
+        r: Math.random() * 1.2 + 0.3,
+        a: Math.random() * 0.5 + 0.2,
+        speed: Math.random() * 0.0008 + 0.0003,
+        phase: Math.random() * Math.PI * 2
+      });
+    }
+  }
+
+  function draw(t) {
+    ctx.clearRect(0, 0, canvas.width, canvas.height);
+    for (const s of stars) {
+      const flicker = 0.5 + 0.5 * Math.sin(t * s.speed * 1000 + s.phase);
+      ctx.globalAlpha = s.a * flicker;
+      ctx.fillStyle = '#fff';
+      ctx.beginPath();
+      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
+      ctx.fill();
+    }
+    requestAnimationFrame(draw);
+  }
+
+  window.addEventListener('resize', () => { resize(); init(); });
+  init();
+  requestAnimationFrame(draw);
+})();
+
+// ── Scroll Reveal ───────────────────────────────────────────
+const revealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-right');
+const revealObs = new IntersectionObserver((entries) => {
+  entries.forEach(entry => {
+    if (entry.isIntersecting) entry.target.classList.add('visible');
+  });
+}, { threshold: 0.1 });
+revealEls.forEach(el => revealObs.observe(el));
+
+// ── Topbar on scroll ────────────────────────────────────────
+const topbar = document.getElementById('topbar');
+window.addEventListener('scroll', () => {
+  topbar.classList.toggle('scrolled', window.scrollY > 80);
+}, { passive: true });
+
+// ── Lightbox ────────────────────────────────────────────────
+(function() {
+  let overlay = null;
+
+  function closeLightbox() {
+    if (!overlay) return;
+    const el = overlay;
+    overlay = null;
+    el.classList.remove('active');
+    setTimeout(() => el.remove(), 350);
+  }
+
+  document.querySelectorAll('[data-lightbox]').forEach(box => {
+    box.addEventListener('click', () => {
+      if (overlay) return;
+      const src = box.querySelector('img').src;
+      const alt = box.querySelector('img').alt;
+
+      overlay = document.createElement('div');
+      overlay.className = 'lightbox-overlay';
+      const img = document.createElement('img');
+      img.src = src;
+      img.alt = alt;
+      overlay.appendChild(img);
+      document.body.appendChild(overlay);
+
+      requestAnimationFrame(() => overlay.classList.add('active'));
+
+      overlay.addEventListener('click', closeLightbox);
+    });
+  });
+
+  document.addEventListener('keydown', (e) => {
+    if (e.key === 'Escape') closeLightbox();
+  });
+})();
+
+// ── Video Thumbnail Click-to-Play ───────────────────────────
+(function() {
+  // Load YouTube IFrame API
+  var tag = document.createElement('script');
+  tag.src = 'https://www.youtube.com/iframe_api';
+  document.head.appendChild(tag);
+
+  document.querySelectorAll('.vessel-video').forEach(el => {
+    // Save original thumbnail HTML for restoration
+    const originalHTML = el.innerHTML;
+    let ytPlayer = null;
+    let inactivityTimer = null;
+
+    function revertToThumbnail() {
+      clearTimeout(inactivityTimer);
+      if (ytPlayer) { try { ytPlayer.destroy(); } catch(e) {} ytPlayer = null; }
+      el.innerHTML = originalHTML;
+      el.classList.remove('playing');
+      document.removeEventListener('click', outsideClickHandler, true);
+    }
+
+    // Revert when scrolled entirely off-screen
+    var scrollObserver = new IntersectionObserver(function(entries) {
+      entries.forEach(function(entry) {
+        if (!entry.isIntersecting && el.classList.contains('playing')) {
+          revertToThumbnail();
+        }
+      });
+    }, { threshold: 0 });
+    scrollObserver.observe(el);
+
+    function resetInactivityTimer() {
+      clearTimeout(inactivityTimer);
+      inactivityTimer = setTimeout(revertToThumbnail, 60000);
+    }
+
+    function outsideClickHandler(e) {
+      if (!el.contains(e.target)) {
+        revertToThumbnail();
+      }
+    }
+
+    el.addEventListener('click', function handler(e) {
+      // Ignore clicks if already playing (let YouTube handle those)
+      if (el.classList.contains('playing')) return;
+
+      const id = el.dataset.videoId;
+      if (!id) return;
+
+      // Replace thumbnail with a div for the YT player
+      var playerDiv = document.createElement('div');
+      playerDiv.id = 'yt-player-' + id + '-' + Date.now();
+      el.innerHTML = '';
+      el.appendChild(playerDiv);
+      el.classList.add('playing');
+
+      // Wait for API to be ready, then create player
+      function createPlayer() {
+        ytPlayer = new YT.Player(playerDiv.id, {
+          videoId: id,
+          playerVars: { autoplay: 1, rel: 0 },
+          events: {
+            onStateChange: function(event) {
+              // YT.PlayerState: PAUSED=2, ENDED=0
+              if (event.data === YT.PlayerState.PAUSED) {
+                resetInactivityTimer();
+              } else if (event.data === YT.PlayerState.ENDED) {
+                revertToThumbnail();
+              } else if (event.data === YT.PlayerState.PLAYING) {
+                clearTimeout(inactivityTimer);
+              }
+            }
+          }
+        });
+      }
+
+      if (window.YT && YT.Player) {
+        createPlayer();
+      } else {
+        // API not yet loaded; queue via global callback
+        var prev = window.onYouTubeIframeAPIReady;
+        window.onYouTubeIframeAPIReady = function() {
+          if (prev) prev();
+          createPlayer();
+        };
+      }
+
+      // Listen for clicks outside the video
+      setTimeout(() => {
+        document.addEventListener('click', outsideClickHandler, true);
+      }, 100);
+    });
+  });
+})();
+
+// ── Hero Parallax ───────────────────────────────────────────
+const heroBg = document.getElementById('heroBg');
+const heroSection = document.getElementById('hero');
+window.addEventListener('scroll', () => {
+  const rect = heroSection.getBoundingClientRect();
+  if (rect.bottom > 0) {
+    const offset = window.scrollY * 0.3;
+    heroBg.style.transform = `translateY(${offset}px)`;
+  }
+}, { passive: true });
+
 
