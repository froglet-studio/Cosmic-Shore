  m_Name: SO_GameTipsList
  m_EditorClassIdentifier: 
  gameModeTips:
  - GameMode: 33
    Tips:
    - Skim closer to prisms to get boost
    - Go after your team crystal
    - Use your triggers to drift around corners
    - Dont worry if you fall behind, the comeback system has got you
  - GameMode: 35
    Tips:
    - Collect as many crystals possible before time runs out
    - Do not collide with prism, it resets your boost
    - Use drifting to get a wide view of the arena
  - GameMode: 34
    Tips:
    - Overtake closely your opponents to joust them
    - The faster gets the joust point
  - GameMode: 7
    Tips:
    - Collide with shapes to create shapes
    - Brake efficiently to get higher accuracy
    - Just have fun, its freestyle
  generalTips: []
